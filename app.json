{
  "expo": {
    "name": "CANY",
    "slug": "smartscan",
    "scheme": "cany",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F8FA"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#92BEEF"
      },
      "package": "com.yourname.smartscan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.yourname.cany",
      "infoPlist": {
        "NSCameraUsageDescription": "CANY needs camera access to scan grocery price tags."
      }
    },
    "extra": {
      "eas": {
        "projectId": "47ff032e-fb7d-4f00-9c0c-bab604b0aefd"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
